                patch = matrix[r:r+3, c:c+3]
                if patch.shape != (3, 3): continue
                
                # Apply an aperiodic scaling multiplier to secure local fields
                patch_weight = np.sum(patch * self.lo_shu_base) * self.PHI % 1.0
                
                # Select a Tangram primitive index based on the normalized local scale
                tangram_id = int(patch_weight * self.NUM_TANGRAMS)
                quantized_tokens.append(tangram_id)
                
        return quantized_tokens

    def resolve_stomachion_routing(self, token_stream: list) -> int:
