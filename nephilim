#!/data/data/com.termux/files/usr/bin/bash
set -e
ROOT=~/nephilim
cd $ROOT

case "$1" in
  switch)
    SPEC=${2:-nephilim}
    echo "→ $SPEC"
    cd compiler && cargo run --quiet ../${SPEC}.spec
    cd ../core && cargo build --quiet
    echo "$SPEC" > ../.current_spec
    ;;
  build)
    SPEC=$(cat .current_spec 2>/dev/null || echo "nephilim")
    cd compiler && cargo run --quiet ../${SPEC}.spec
    cd ../core && cargo build --quiet
    ;;
  info)
    cd core && cargo run --quiet
    ;;
  *)
    echo "usage: nephilim switch|build|info"
    ;;
esac
