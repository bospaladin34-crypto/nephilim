#!/data/data/com.termux/files/usr/bin/bash
set -e
ROOT=~/nephilim
cd $ROOT

case "$1" in
  switch)
    SPEC=${2:-nephilim}
    echo "→ $SPEC"
    cd compiler && cargo run --quiet -- ../${SPEC}.spec
    cd ../core && cargo build --quiet
    echo "$SPEC" > ../.current_spec
    ;;
  build)
    SPEC=$(cat .current_spec 2>/dev/null || echo "nephilim")
    cd compiler && cargo run --quiet -- ../${SPEC}.spec
    cd ../core && cargo build --quiet
    ;;
  info)
    cd core && cargo run --quiet
    ;;
  points)
    N=${2:-100}
    cd core
    OUT=$(cargo run --quiet -- $N)
    echo "$OUT" | head -20
    ;;
  braid)
    N=${2:-20}
    cd core
    OUT=$(cargo run --quiet -- $N)
    echo "$OUT" | awk '/^---BRAID---/{p=1;next} p'
    ;;
  latent)
    WORD=${2:-consciousness}
    cd core && cargo run --quiet -- latent "$WORD"
    ;;
  compare)
    N=${2:-100}
    $0 switch nephilim >/dev/null
    $0 points $N >/dev/null
    $0 switch erdos >/dev/null
    $0 points $N >/dev/null
    ;;
  *)
    echo "usage: nephilim switch|build|info|points [N]|braid [N]|latent [word]|compare [N]"
    ;;
esac
