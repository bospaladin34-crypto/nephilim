#!/data/data/com.termux/files/usr/bin/bash
set -e
ROOT=~/nephilim
cd $ROOT

case "$1" in
  switch)
    SPEC=${2:-nephilim}
    cp "${SPEC}.spec" nephilim.spec
    echo "→ $SPEC"
    cd compiler && cargo run --quiet ../nephilim.spec
    cd ../core && cargo build --quiet
    ;;
  build)
    cd compiler && cargo run --quiet ../nephilim.spec
    cd ../core && cargo build --quiet
    ;;
  info)
    cd core && cargo run --quiet
    ;;
  *)
    echo "usage: nephilim switch|build|info"
    ;;
esac
