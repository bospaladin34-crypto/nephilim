#!/bin/bash
set -e
CORE=./core/target/release/nephilim-core
SPEC_DIR=./specs

cmd=$1; shift || true

case "$cmd" in
  switch)
    name=${1:-vesper}
    echo "$name.spec" >.current_spec
    cp "$SPEC_DIR/$name.spec" current.spec 2>/dev/null || true
    echo "→ $name"
    $CORE --info
    ;;
  hash)
    $CORE "$@"
    ;;
  status)
    echo "--- Nephilim Status ---"
    cat.current_spec 2>/dev/null | xargs echo "spec:"
    $CORE --info
    ;;
  *)
    echo "usage:./nephilim switch [vesper|nephilim|erdos] | hash <text> | status"
    ;;
esac
